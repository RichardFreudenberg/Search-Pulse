{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "storage.rules",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "pipeline/**",
      "serve.bat",
      "serve.ps1"
    ]
  }
}
