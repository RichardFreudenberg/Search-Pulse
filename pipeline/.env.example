# ─── SearchPulse Pipeline — Environment Variables ────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Required ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Docker default shown)
DATABASE_URL=postgresql://pipeline:pipeline@localhost:5432/pipeline

# Redis URL (Docker default shown)
REDIS_URL=redis://localhost:6379/0

# ── Firebase (sync back to CRM) ───────────────────────────────────────────────
# Path to your serviceAccountKey.json from Firebase Console
FIREBASE_CREDENTIALS_PATH=./config/serviceAccountKey.json

# Your Firebase project ID (shown in Firebase Console → Project Settings)
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Optional: LLM fallback for document extraction ────────────────────────────
# Only needed if you want LLM-assisted extraction of scanned PDFs
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: document storage path ──────────────────────────────────────────
DOCUMENT_STORAGE_PATH=./data/documents

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
