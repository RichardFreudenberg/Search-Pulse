# functions/.env.example
# ──────────────────────
# Copy this file to functions/.env and fill in your master account API keys.
# These keys live ONLY on the server and are never exposed to the browser.
#
# After editing functions/.env, deploy with:
#   firebase deploy --only functions
#
# DO NOT commit functions/.env (it is in .gitignore)

# OpenAI key — preferred (uses gpt-4o-mini, very cheap)
OPENAI_KEY=sk-...

# Claude key — fallback if OPENAI_KEY is empty (uses claude-3-5-haiku)
CLAUDE_KEY=sk-ant-...

# Apify token — used by "Fetch Handelsregister officers" feature
APIFY_KEY=apify_api_...

# Tavily key — used by "Web Research" feature on company popups
# (fetches website, HQ, key people, recent news)
# Get your key at https://tavily.com (1000 free searches/month)
TAVILY_KEY=tvly-...
